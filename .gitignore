# MADiff-T public release — minimal allowlist gitignore.
# Repo is structured as a single deliverable under madifft_final/.
# Everything at the root level is excluded except the items below.

/*
!/.gitignore
!/README.md
!/CITATION.cff
!/requirements.txt
!/madifft_final/

# Global junk / environments / caches (recursive)
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.ipynb_checkpoints/
**/*.tmp
**/*.temp
**/*.bak
**/*.orig
**/*.rej
**/*.zip
**/*.log
.DS_Store
Thumbs.db
.idea/
.vscode/
.venv/
venv/
env/
