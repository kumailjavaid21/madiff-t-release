paper_revC/results_revC/POP6_SEEDED_20260321/*
!paper_revC/results_revC/POP6_SEEDED_20260321/run_manifest.json
!paper_revC/results_revC/POP6_SEEDED_20260321/tables/
!paper_revC/results_revC/POP6_SEEDED_20260321/tables/**

paper_revC/results_revC/DOMIAS_POP6_SEEDED_20260321/*
!paper_revC/results_revC/DOMIAS_POP6_SEEDED_20260321/tables/
paper_revC/results_revC/DOMIAS_POP6_SEEDED_20260321/tables/*
!paper_revC/results_revC/DOMIAS_POP6_SEEDED_20260321/tables/privacy_strong_audits_raw.csv

paper_revC/results_revC/ABL_ORIG_M6_SEEDED_20260322/*
!paper_revC/results_revC/ABL_ORIG_M6_SEEDED_20260322/tables/
paper_revC/results_revC/ABL_ORIG_M6_SEEDED_20260322/tables/*
!paper_revC/results_revC/ABL_ORIG_M6_SEEDED_20260322/tables/tstr_results_raw.csv

